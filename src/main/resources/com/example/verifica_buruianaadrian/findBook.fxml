<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" prefHeight="452.0" prefWidth="690.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.verifica_buruianaadrian.controller.findBookController">
   <children>
      <AnchorPane prefHeight="554.0" prefWidth="690.0">
         <children>
            <Label layoutX="311.0" layoutY="14.0" text="Ricerca">
               <font>
                  <Font name="System Bold" size="20.0" />
               </font>
            </Label>
            <HBox layoutX="1.0" layoutY="79.0" prefHeight="373.0" prefWidth="690.0">
               <children>
                  <VBox prefHeight="373.0" prefWidth="341.0">
                     <children>
                        <RadioButton fx:id="oISBN" mnemonicParsing="false" onAction="#ordinamentoPerISBN" text="Ordinamento per ISBN" />
                        <RadioButton fx:id="oPos" mnemonicParsing="false" onAction="#ordinamentoPosizione" text="Ordinamento per Posizione">
                           <opaqueInsets>
                              <Insets />
                           </opaqueInsets>
                           <VBox.margin>
                              <Insets top="20.0" />
                           </VBox.margin>
                        </RadioButton>
                        <RadioButton fx:id="oTitolo" mnemonicParsing="false" onAction="#ordinamentoPerTitolo" selected="true" text="Ordinamento per Titolo">
                           <opaqueInsets>
                              <Insets />
                           </opaqueInsets>
                           <VBox.margin>
                              <Insets top="20.0" />
                           </VBox.margin>
                        </RadioButton>
                     </children>
                  </VBox>
                  <TextArea fx:id="textArea" editable="false" prefHeight="373.0" prefWidth="531.0" />
               </children>
            </HBox>
            <Button layoutX="625.0" layoutY="14.0" mnemonicParsing="false" onAction="#tornaMenu" text="Menu" />
         </children>
      </AnchorPane>
   </children>
</VBox>
