<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="TOP_CENTER" prefHeight="464.0" prefWidth="690.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.verifica_buruianaadrian.controller.addBooksController">
   <children>
      <GridPane maxHeight="-Infinity" maxWidth="687.0" minHeight="-Infinity" minWidth="-Infinity" prefHeight="363.0" prefWidth="687.0">
