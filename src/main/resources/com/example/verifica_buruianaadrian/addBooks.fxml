                  <Label text="ISBN:" />
                  <TextField fx:id="ISBN" maxHeight="-Infinity" maxWidth="-Infinity" promptText="Inserisci ISBN" />
                  <Label text="Titolo:" />
                  <TextField maxHeight="-Infinity" maxWidth="-Infinity" promptText="Inserisci titolo" />
                  <Label text="Autore:" />
                  <TextField maxHeight="-Infinity" maxWidth="-Infinity" promptText="Inserisci autore" />
