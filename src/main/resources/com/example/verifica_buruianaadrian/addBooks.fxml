                     </VBox.margin>
                  </ComboBox>
               </children>
            </VBox>
         </children>
      </GridPane>
      <Button alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" text="Conferma" textAlignment="JUSTIFY" />
